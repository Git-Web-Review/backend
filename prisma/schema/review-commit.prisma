model ReviewCommit {
    id               String   @id @default(uuid())
    reviewId         String   @map("review_id")
    review           Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
    hash             String
    title            String
    signedOffByName  String   @map("signed_off_by_name")
    signedOffByEmail String   @map("signed_off_by_email")
    fixesHash        String?  @map("fixes_hash")
    fixesTitle       String?  @map("fixes_title")
    rawMessage       String   @map("raw_message")
    createdAt        DateTime @default(now()) @map("created_at")

    @@unique([reviewId, hash])
    @@map("review_commits")
}
